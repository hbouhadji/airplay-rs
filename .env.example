# Android SDK / NDK
ANDROID_HOME=/path/to/Android/sdk
ANDROID_NDK_ROOT=/path/to/Android/sdk/ndk/<ndk-version>

# GStreamer Android SDK, containing arm64/, armv7/, x86/, and x86_64/.
GSTREAMER_ROOT_ANDROID=/path/to/gstreamer-1.0-android-universal

# Allow pkg-config use while cross-compiling.
PKG_CONFIG_ALLOW_CROSS=1
