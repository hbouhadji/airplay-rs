+static gboolean
+parse_h265_decoder_config_record (GstVtdec * vtdec, GstBuffer * codec_data,
+    GstH265DecoderConfigRecord ** config)
+{
+  GstH265Parser *parser = gst_h265_parser_new ();
+  GstMapInfo map;
+  gboolean ret = TRUE;
+
+  gst_buffer_map (codec_data, &map, GST_MAP_READ);
+
+  if (gst_h265_parser_parse_decoder_config_record (parser, map.data, map.size,
+          config) != GST_H265_PARSER_OK) {
+    GST_WARNING_OBJECT (vtdec, "Failed to parse HEVC codec-data");
+    ret = FALSE;
+  }
+
+  gst_h265_parser_free (parser);
+  gst_buffer_unmap (codec_data, &map);
+  return ret;
+}
+
 static gboolean
 get_h264_dpb_size_from_sps (GstVtdec * vtdec, GstH264NalUnit * nalu,
     gint * dpb_size)
@@ -2040,11 +2061,60 @@ static gboolean
 compute_hevc_decode_picture_buffer_size (GstVtdec * vtdec,
     GstBuffer * codec_data, int *length)
 {
-  /* This value should be level dependent (table A.8)
-   * but let's assume the maximum possible one for simplicity. */
   const gint max_luma_ps = 35651584;
   const gint max_dpb_pic_buf = 6;
+  GstH265DecoderConfigRecord *config = NULL;
   gint max_dbp_size, pic_size_samples_y;
+  gboolean found_sps = FALSE;
+  guint i, j;
+
+  *length = 0;
+
+  if (parse_h265_decoder_config_record (vtdec, codec_data, &config)) {
+    for (i = 0; i < config->nalu_array->len; i++) {
+      GstH265DecoderConfigRecordNalUnitArray *array =
+          &g_array_index (config->nalu_array,
+          GstH265DecoderConfigRecordNalUnitArray, i);
+
+      if (array->nal_unit_type != GST_H265_NAL_SPS)
+        continue;
+
+      for (j = 0; j < array->nalu->len; j++) {
+        GstH265Parser *parser = gst_h265_parser_new ();
+        GstH265NalUnit *nalu =
+            &g_array_index (array->nalu, GstH265NalUnit, j);
+        GstH265SPS sps;
+        GstH265ParserResult result;
+        gint reorder_size;
+
+        result = gst_h265_parser_parse_sps (parser, nalu, &sps, FALSE);
+        gst_h265_parser_free (parser);
+
+        if (result != GST_H265_PARSER_OK) {
+          GST_WARNING_OBJECT (vtdec, "Failed to parse HEVC SPS");
+          continue;
+        }
+
+        reorder_size =
+            sps.max_num_reorder_pics[sps.max_sub_layers_minus1];
+        GST_INFO_OBJECT (vtdec,
+            "parsed HEVC SPS max_num_reorder_pics %d", reorder_size);
+
+        *length = MAX (*length, reorder_size);
+        found_sps = TRUE;
+      }
+    }
+
+    gst_h265_decoder_config_record_free (config);
+
+    if (found_sps)
+      return TRUE;
+  }
+
+  /* Fallback to the upstream conservative estimate if codec-data does not
+   * carry a parseable SPS. AirPlay mirroring normally advertises
+   * sps_max_num_reorder_pics = 0, so valid streams still push immediately.
+   */
 
   if (vtdec->video_info.width == 0 || vtdec->video_info.height == 0)
     return FALSE;
